<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:BluetoothTest.ViewModels"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="650"
             x:Class="BluetoothTest.Views.MainView"
             x:DataType="vm:MainViewModel">

    <Design.DataContext>
        <vm:MainViewModel />
    </Design.DataContext>

    <UserControl.Styles>
        <Style Selector="Button.send">
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Width" Value="140"/>
            <Setter Property="Height" Value="140"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.send:disabled /template/ ContentPresenter">
            <Setter Property="Opacity" Value="0.25"/>
        </Style>
        <Style Selector="Button.reconnect">
            <Setter Property="Background" Value="#252540"/>
            <Setter Property="Foreground" Value="#7070A0"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#3A3A55"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.reconnect:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3A3A55"/>
        </Style>
    </UserControl.Styles>

    <Grid Background="#13131F" RowDefinitions="Auto,*,Auto,Auto">

        <!-- Header -->
        <Border Grid.Row="0" Background="#1A1A2E" Padding="24,20">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel>
                    <TextBlock Text="Controllo Luci"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="ESP32-Luce"
                               FontSize="12"
                               Foreground="#5050A0"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Status pill -->
                <Border Grid.Column="1" CornerRadius="20" Padding="14,7" VerticalAlignment="Center">
                    <!-- Connesso -->
                    <Border.IsVisible>
                        <Binding Path="IsConnected"/>
                    </Border.IsVisible>
                    <Border.Background>
                        <SolidColorBrush Color="#0D2A1A"/>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <Ellipse Width="8" Height="8" Fill="#22C55E" VerticalAlignment="Center"/>
                        <TextBlock Text="Connesso" FontSize="12" Foreground="#22C55E" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" CornerRadius="20" Padding="14,7" VerticalAlignment="Center"
                        Background="#1A1A2E"
                        IsVisible="{Binding !IsConnected}">
                    <StackPanel Orientation="Horizontal" Spacing="7">
                        <Ellipse Width="8" Height="8" Fill="#505080" VerticalAlignment="Center"/>
                        <TextBlock Text="Non connesso" FontSize="12" Foreground="#505080" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main controls -->
        <Grid Grid.Row="1" RowDefinitions="*,Auto,*">

            <!-- Bottoni ON/OFF -->
            <StackPanel Grid.Row="1"
                        HorizontalAlignment="Center"
                        Spacing="32">

                <TextBlock Text="CONTROLLA LA LUCE"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#404060"
                           LetterSpacing="2"
                           HorizontalAlignment="Center"/>

                <Grid ColumnDefinitions="Auto,40,Auto">
                    <!-- OFF -->
                    <Button Classes="send"
                            IsEnabled="{Binding IsConnected}"
                            Command="{Binding SendZeroCommand}"
                            Background="#0E1E35"
                            ToolTip.Tip="Spegni">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                            <TextBlock Text="⏻" FontSize="38" Foreground="#2D5A8E" HorizontalAlignment="Center"/>
                            <TextBlock Text="OFF" FontSize="13" FontWeight="Bold" Foreground="#2D5A8E" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Separatore -->
                    <Rectangle Grid.Column="1" Width="1" Fill="#252540" VerticalAlignment="Stretch" Margin="0,20"/>

                    <!-- ON -->
                    <Button Classes="send"
                            Grid.Column="2"
                            IsEnabled="{Binding IsConnected}"
                            Command="{Binding SendOneCommand}"
                            Background="#1A3520"
                            ToolTip.Tip="Accendi">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6">
                            <TextBlock Text="⏻" FontSize="38" Foreground="#22C55E" HorizontalAlignment="Center"/>
                            <TextBlock Text="ON" FontSize="13" FontWeight="Bold" Foreground="#22C55E" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- Reconnect button -->
        <StackPanel Grid.Row="2" HorizontalAlignment="Center" Margin="0,0,0,20" Spacing="10">
            <Button Classes="reconnect"
                    Content="↻  Riconnetti"
                    Command="{Binding LoadDevicesCommand}"
                    HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Error area -->
        <Border Grid.Row="3" Margin="20,0,20,24"
                IsVisible="{Binding LastError, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
            <Border Background="#2D0A0A" CornerRadius="12" Padding="16,12">
                <TextBlock Text="{Binding LastError}"
                           Foreground="#F87171"
                           FontSize="12"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"/>
            </Border>
        </Border>

    </Grid>
</UserControl>
